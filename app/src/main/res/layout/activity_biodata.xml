<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutBiodata"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="#F5F5F5">

    <Switch
        android:id="@+id/switchDarkMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dark Mode"
        android:textColor="#212121"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/txtJudulBiodata"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Biodata Pengguna"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/txtNama"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nama: Mohamad Taufik Wibowo"
        android:textSize="18sp"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/txtProdi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Program Studi: Teknik Informatika"
        android:textSize="18sp"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/txtEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email: taufikm250@gmail.com"
        android:textSize="18sp"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/txtUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Username: -"
        android:textSize="18sp"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textAllCaps="false"
        android:textSize="16sp" />

</LinearLayout>